#!/bin/bash
#
# pre-commit hook: 提交前自动更新 PROJECT.md 并纳入本次提交
#

# 如果设置了 SKIP_HOOK 环境变量，跳过
if [ "$SKIP_HOOK" = "1" ]; then
  exit 0
fi

echo "📝 正在更新 PROJECT.md..."

# 使用 git rev-parse 获取项目根目录
PROJECT_DIR=$(git rev-parse --show-toplevel)

# 运行更新脚本
node "$PROJECT_DIR/scripts/update-project-md.js"

# 如果有变更，自动添加到暂存区，随本次提交一起提交
if ! git diff --quiet "$PROJECT_DIR/PROJECT.md" 2>/dev/null; then
  echo "📄 PROJECT.md 已更新，已自动加入暂存区"
  git add "$PROJECT_DIR/PROJECT.md"
fi
