#!/bin/bash
#
# post-commit hook: 提交完成后自动追加日志条目到 PROJECT.md 并 amend
#

# 如果设置了 SKIP_HOOK 环境变量，跳过
if [ "$SKIP_HOOK" = "1" ]; then
  exit 0
fi

echo "📝 正在追加提交日志到 PROJECT.md..."

# 使用 git rev-parse 获取项目根目录
PROJECT_DIR=$(git rev-parse --show-toplevel)

# 运行更新脚本（追加日志条目）
node "$PROJECT_DIR/scripts/update-project-md.js" --post-commit

# 如果有变更，自动 amend 到刚才的提交
if ! git diff --quiet "$PROJECT_DIR/PROJECT.md" 2>/dev/null; then
  echo "📄 PROJECT.md 日志已更新，自动 amend 到当前提交"
  git add "$PROJECT_DIR/PROJECT.md"
  SKIP_HOOK=1 git commit --amend --no-edit
fi
